# Copy this file to `.env.local` and replace placeholders with values from
# Supabase Dashboard → Project Settings → API.
#
# REQUIRED for Supabase mode (GET /api/aircraft/storage-status → configured: true):
#   - NEXT_PUBLIC_SUPABASE_URL
#   - NEXT_PUBLIC_SUPABASE_ANON_KEY
#   - SUPABASE_SERVICE_ROLE_KEY
#
# If NEXT_PUBLIC_SUPABASE_ANON_KEY is missing, the client falls back to localStorage
# even when the service role key is set. Hydration, flights API, login, and
# realtime all expect the full trio above.

# Public — embedded in the client bundle (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never commit real values; set in Vercel for production
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — defaults to "aircraft-images"
# SUPABASE_AIRCRAFT_IMAGES_BUCKET=aircraft-images
